ANDROID_KEYSTORE_PATH="/absolute/path/to/android-signing.jks"
ANDROID_KEY_ALIAS="replace-me-or-leave-empty-to-auto-detect"
ANDROID_KEYSTORE_PASSWORD="replace-me"
ANDROID_KEY_PASSWORD="replace-me"
NOSTR_KEY_PATH="/absolute/path/to/nostr-key-file"

# Optional overrides.
# KEYSTORE_DNAME="CN=Nostr VPN, OU=Mobile, O=Iris, L=Helsinki, S=Uusimaa, C=FI"
# ZAPSTORE_CHANNEL="main"
# GITHUB_TOKEN="ghp_..."
# SIGN_WITH="nsec1..."
# SKIP_PUBLISH="1"
# ZSP_AUTO_CONFIRM="0"
# ZSP_SKIP_PREVIEW="0"
# ZSP_EXTRA_FLAGS="--overwrite-release"
# INSTALL_ON_DEVICE="1"
# CAPTURE_SCREENSHOT="1"
# SCREENSHOT_PATH="$PWD/artifacts/android/nostr-vpn-home.png"
