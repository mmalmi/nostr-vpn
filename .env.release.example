# Optional overrides for scripts/local-release.mjs.
# Copy to .env.release.local and edit locally when you need machine-specific paths.

# htree release tree name
# NVPN_RELEASE_TREE=releases/nostr-vpn

# Include Zapstore publication when running scripts/local-release.mjs.
# Requires the Android signing and Nostr signer vars from .env.zapstore.local.
# NVPN_PUBLISH_ZAPSTORE=1

# Select a specific Parallels Windows VM instead of auto-detecting one running Windows guest.
# NVPN_WINDOWS_VM_NAME=Windows 11

# Override the repo paths used when mirroring the checkout into the Windows VM.
# NVPN_WINDOWS_SHARED_REPO_PATH=C:\Mac\Home\src\nostr-vpn
# NVPN_WINDOWS_REPO_PATH=C:\Users\you\src\nostr-vpn

# Windows targets to build in the VM.
# CLI defaults to x86_64 and aarch64. GUI defaults to x86_64.
# NVPN_WINDOWS_CLI_TARGETS=x86_64-pc-windows-msvc,aarch64-pc-windows-msvc
# NVPN_WINDOWS_GUI_TARGETS=x86_64-pc-windows-msvc

# Optional LLVM location for Windows ARM builds that need clang (for example ring on aarch64).
# NVPN_WINDOWS_LLVM_BIN=C:\Program Files\LLVM\bin

# Android signing is optional. These reuse the same variables as the Android Zapstore script.
# ANDROID_KEYSTORE_PATH=/absolute/path/to/upload-keystore.jks
# ANDROID_KEYSTORE_PASSWORD=change-me
# ANDROID_KEY_ALIAS=nostr-vpn-upload
# ANDROID_KEY_PASSWORD=change-me

# If you prefer to keep the keystore in the env file instead of on disk:
# ANDROID_KEYSTORE_B64=base64-encoded-jks
